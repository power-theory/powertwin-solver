# Mode
DEV_MODE=true                              # set false for prod-style image builds

# Postgres
PG_DB_TOKEN_ADMIN=changeme
PG_DB_PORT=5432

# Shared HTTP api-token (db API → Flask, Flask → MSS, MSS → Flask)
API_SOLVER_TOKEN=changeme

# Flask
FLASK_PORT=1337

# Simulation
URBANOPT_SIMULATION_YEAR=2026                       # calendar year the sim runs against
URBANOPT_REPORTING_FREQUENCY=Timestep               # Detailed, Timestep, Hourly, Daily, BillingPeriod, Monthly, Runperiod
URBANOPT_RESAMPLE=                         # post-process resample period. '' (native) | H | D | W | M | Y
URBANOPT_POSTPROCESS_TRANSLATIONS=false    # apply custom -1s shift + noon-on-1st monthly. false = vanilla pandas grouping

# MSS (optional - only needed for docker-compose-prod.yml)
# FLASK_MSS_BASE_URL=http://powertwin-solver-flask
# CI_COMMIT_BRANCH=
# POWERTWIN_LOG_DIR=/path/to/log/dir
# MSS_PORT=8000
# MSS_SLACK_VERIFICATION_TOKEN=changeme
# MSS_SLACK_SIGNING_SECRET=changeme
# MSS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/X/Y/Z
# MSS_SLACK_CHANNEL=solver
