  <class_name>SetWindowConstruction</class_name>
  <display_name>Set Window Construction</display_name>
  <description>Build a SimpleGlazing from given U-factor + SHGC and assign to all exterior windows.</description>
  <modeler_description>Pure applier: caller supplies U-factor (W/m2-K) and SHGC. Builds an OS:SimpleGlazing + OS:Construction and reassigns FixedWindow/OperableWindow subsurfaces.</modeler_description>
  <arguments>
    <argument>
      <name>u_factor</name>
      <display_name>Window U-factor (W/m2-K)</display_name>
      <type>Double</type>
      <required>true</required>
      <model_dependent>false</model_dependent>
      <default_value>3.12</default_value>
    </argument>
    <argument>
      <name>shgc</name>
      <display_name>Window SHGC (0-1)</display_name>
      <type>Double</type>
      <required>true</required>
      <model_dependent>false</model_dependent>
      <default_value>0.40</default_value>
    </argument>
  </arguments>
