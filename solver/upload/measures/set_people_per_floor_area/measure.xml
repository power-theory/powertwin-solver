  <class_name>SetPeoplePerFloorArea</class_name>
  <display_name>Set Total Occupants</display_name>
  <description>Rescale every People object so the building total equals target_total.</description>
  <modeler_description>Computes the model's current total people count (sum of space.numberOfPeople), then applies a uniform scalar to each People object's peoplePerFloorArea / numberofPeople / spaceFloorAreaperPerson so the new total matches target_total. Preserves the relative density distribution.</modeler_description>
  <arguments>
    <argument>
      <name>target_total</name>
      <display_name>Target total occupants</display_name>
      <type>Integer</type>
      <required>true</required>
      <model_dependent>false</model_dependent>
      <default_value>1</default_value>
    </argument>
  </arguments>
  <outputs/>
